<?xml version="1.0"?>
<rdf:RDF xmlns="https://w3id.org/mdivo#"
     xml:base="https://w3id.org/mdivo"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:mdivo="https://w3id.org/mdivo#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:swrlb="http://www.w3.org/2003/11/swrlb#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="https://w3id.org/mdivo">
        <owl:versionIRI rdf:resource="https://w3id.org/mdivo/1.0"/>
        <terms:creator xml:lang="en">Nil Arilla</terms:creator>
        <terms:license>https://creativecommons.org/licenses/by/4.0/</terms:license>
        <terms:title xml:lang="en">MDIVO Ontology</terms:title>
        <rdfs:comment xml:lang="en">Ontology for the European catalogue of high risk medical devices and in-vitro diagnostic devices, aligned with EU Regulations MDR (2017/745) and IVDR (2017/746) and the EUDAMED database.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Devices and In-Vitro Diagnostics Ontology (MDIVO)</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- http://purl.org/dc/terms/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/title"/>
    


    <!-- http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled -->


    <owl:AnnotationProperty rdf:about="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2001/XMLSchema#date -->


    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mdivo#affectsDevice -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#affectsDevice">
        <owl:inverseOf rdf:resource="https://w3id.org/mdivo#hasIncident"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Links an incident to the medical device involved in the adverse event</rdfs:comment>
        <rdfs:label xml:lang="en">affects device</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#fallsUnder -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#fallsUnder">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#RegulatoryFramework"/>
        <rdfs:label xml:lang="en">Links a medical device to its applicable regulatory framework</rdfs:label>
        <rdfs:label xml:lang="en">falls under</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#hasEstablishmentCountry -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#hasEstablishmentCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Country"/>
        <rdfs:comment xml:lang="en">Country where the manufacturer is legally established</rdfs:comment>
        <rdfs:label xml:lang="en">has establishment country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#hasFSCA -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#hasFSCA">
        <owl:inverseOf rdf:resource="https://w3id.org/mdivo#respondsToIncident"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:comment xml:lang="en">Inverse of :respondsToIncident</rdfs:comment>
        <rdfs:label xml:lang="en">has FSCA</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#hasIncident -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#hasIncident">
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:comment xml:lang="en">Inverse of :affectsDevice</rdfs:comment>
        <rdfs:label xml:lang="en">has incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#hasReportingCountry -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#hasReportingCountry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Country"/>
        <rdfs:comment xml:lang="en">Country in whose territory the incident was reported</rdfs:comment>
        <rdfs:label xml:lang="en">has reporting country</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#hasReportingEntity -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#hasReportingEntity">
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:comment xml:lang="en">Entity that submitted the incident notification to EUDAMED</rdfs:comment>
        <rdfs:label xml:lang="en">has reporting entity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#hasRiskClass -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#hasRiskClass">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Links a medical device to its risk classification</rdfs:comment>
        <rdfs:label xml:lang="en">has risk class</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#isManufacturedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#isManufacturedBy">
        <owl:inverseOf rdf:resource="https://w3id.org/mdivo#manufactures"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:comment xml:lang="en">Links a medical device to the legal manufacturer that placed it on the market</rdfs:comment>
        <rdfs:label xml:lang="en">is manufactured by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#isSupervisedBy -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#isSupervisedBy">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#CompetentAuthority"/>
        <rdfs:comment xml:lang="en">National competent authority responsible for the supervision of the manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">is supervised by</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#manufactures -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#manufactures">
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Inverse of :isManufacturedBy</rdfs:comment>
        <rdfs:label xml:lang="en">manufactures</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#realizesRisk -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#realizesRisk">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">An incident is the actual realization of a previosuly identified IMDRF risk</rdfs:comment>
        <rdfs:label xml:lang="en">realizes risk</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://w3id.org/mdivo#respondsToIncident -->


    <owl:ObjectProperty rdf:about="https://w3id.org/mdivo#respondsToIncident">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:range rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:comment xml:lang="en">Links a FSCA to the incident that motivated it</rdfs:comment>
        <rdfs:label xml:lang="en">responds to incident</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mdivo#hasActionDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasActionDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date on which the FSCA was issued</rdfs:comment>
        <rdfs:label xml:lang="en">has action date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasAuthorizationNumber -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasAuthorizationNumber">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">National authorization number issued by the competent authority.</rdfs:comment>
        <rdfs:label xml:lang="en">has authorization number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasClosureDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasClosureDate">
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date on which the FSCA was officially closed.</rdfs:comment>
        <rdfs:label xml:lang="en">has closure date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasContactEmail -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasContactEmail">
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Public regulatory contact e-mail of the manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has contact email</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasDeviceName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasDeviceName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Commercial name of the medical device as registered in EUDAMED</rdfs:comment>
        <rdfs:label xml:lang="en">has device name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasDevicesAffectedCount -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasDevicesAffectedCount">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Approximate number of devices affected by the FSCA</rdfs:comment>
        <rdfs:label xml:lang="en">has devices affected count</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasEudamedFSCARef -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasEudamedFSCARef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier of the FSCA in EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED FSCA reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasEudamedIncidentRef -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasEudamedIncidentRef">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique identifier of the incident in EUDAMED</rdfs:comment>
        <rdfs:label xml:lang="en">has EUDAMED incident reference</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasEventDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasEventDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date on which the clinical event actually occurred</rdfs:comment>
        <rdfs:label xml:lang="en">has event date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasIMDRFCode -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasIMDRFCode">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Code from the IMDRF Adverse Event Terminology</rdfs:comment>
        <rdfs:label xml:lang="en">has IMDRF Code</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasIntendedPurpose -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasIntendedPurpose">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Use for which a device is intended according to the manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has intended purpose</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasOrgName -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasOrgName">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Legal trade name of the organization</rdfs:comment>
        <rdfs:label xml:lang="en">has organization name</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasOutcome -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasOutcome">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Brief description of the clinical outcome of the incident</rdfs:comment>
        <rdfs:label xml:lang="en">has outcome</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasPatientAge -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasPatientAge">
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment xml:lang="en">Age in years of the patient affected by the incident</rdfs:comment>
        <rdfs:label xml:lang="en">has patient age</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasProbability -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasProbability">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Probability level of risk occurrence</rdfs:comment>
        <rdfs:label xml:lang="en">has probability</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasReportDate -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasReportDate">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment xml:lang="en">Date on which the incident was officially reported to EUDAMED.</rdfs:comment>
        <rdfs:label xml:lang="en">has report date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasSRN -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasSRN">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Single Registration Number assigned by EUDAMED to each manufacturer</rdfs:comment>
        <rdfs:label xml:lang="en">has SRN</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasSeverity -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasSeverity">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Severity level of the risk</rdfs:comment>
        <rdfs:label xml:lang="en">has severity</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasStatus -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasStatus">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Status of the FSCA</rdfs:comment>
        <rdfs:label xml:lang="en">has status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#hasUDI -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#hasUDI">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment xml:lang="en">Unique Device Identifier - Device Identifier</rdfs:comment>
        <rdfs:label xml:lang="en">has UDI</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#isActive -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#isActive">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean flag used by the reasoner to classify the device as ActiveDevice</rdfs:comment>
        <rdfs:label xml:lang="en">is active</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#isIVD -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#isIVD">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean flag used by the reasoner to infer that the device falls under IVDR</rdfs:comment>
        <rdfs:label xml:lang="en">is IVD</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#isImplantable -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#isImplantable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean flag used by the reasoner to classify the device as ImplantableDevice</rdfs:comment>
        <rdfs:label xml:lang="en">is implantable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://w3id.org/mdivo#isReusable -->


    <owl:DatatypeProperty rdf:about="https://w3id.org/mdivo#isReusable">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment xml:lang="en">Boolean flag indicating whether the device may be reused after sterilisation</rdfs:comment>
        <rdfs:label xml:lang="en">is reusable</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- https://w3id.org/mdivo#ActiveDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ActiveDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A medical device whose operation depends on a source of energy other than that generated by the human body or gravity</rdfs:comment>
        <rdfs:label xml:lang="en">Active Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassA -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassA">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Lowest IVDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class A</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassB -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassB">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Low medium IVDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class B</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassC -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassC">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Medium high IVDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class C</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassD -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassD">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Highest IVDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class D</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassI -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassI">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Lowest MDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class I</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassIII -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassIII">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Highest MDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class III</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassIIa -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassIIa">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Medium low MDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIa</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ClassIIb -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ClassIIb">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RiskClass"/>
        <rdfs:comment xml:lang="en">Medium high MDR risk class</rdfs:comment>
        <rdfs:label xml:lang="en">Class IIb</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#CompetentAuthority -->


    <owl:Class rdf:about="https://w3id.org/mdivo#CompetentAuthority">
        <rdfs:comment xml:lang="en">National authority responsible for supervising medical device manufacturers and the post market surveillance system within an EU member state.</rdfs:comment>
        <rdfs:label xml:lang="en">Competent Authority</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#Country -->


    <owl:Class rdf:about="https://w3id.org/mdivo#Country">
        <rdfs:comment xml:lang="en">A sovereign state, used to model the country of establishment of a manufacturer and the country in which an incident is reported.</rdfs:comment>
        <rdfs:label xml:lang="en">Country</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#CybersecurityRisk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#CybersecurityRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">Risk arising from inadequate protection against unauthorized access or modification of a device or its data</rdfs:comment>
        <rdfs:label xml:lang="en">Cybersecurity Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#DiagnosticRisk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#DiagnosticRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">Risk of erroneous diagnostic results, including false positives or false negatives</rdfs:comment>
        <rdfs:label xml:lang="en">Diagnostic Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#FSCA -->


    <owl:Class rdf:about="https://w3id.org/mdivo#FSCA">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#respondsToIncident"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/mdivo#Incident"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Action taken by a manufacturer to reduce the risk of death or serious deterioration in health associated with the use of a device</rdfs:comment>
        <rdfs:label xml:lang="en">Field Safety Corrective Action</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#IVDR -->


    <owl:Class rdf:about="https://w3id.org/mdivo#IVDR">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RegulatoryFramework"/>
        <owl:disjointWith rdf:resource="https://w3id.org/mdivo#MDR"/>
        <rdfs:comment xml:lang="en">Regulation (EU) 2017/746 on in-vitro diagnostic medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">IVDR Framework</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ImplantableActiveDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ImplantableActiveDevice">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="https://w3id.org/mdivo#MedicalDevice"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/mdivo#isActive"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="https://w3id.org/mdivo#isImplantable"/>
                        <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:hasValue>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Active device intended for implantation</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Active Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#ImplantableDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#ImplantableDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device intended to be totally or partially introduced into the human body and to remain there for at least 30 days</rdfs:comment>
        <rdfs:label xml:lang="en">Implantable Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#InSituCorrection -->


    <owl:Class rdf:about="https://w3id.org/mdivo#InSituCorrection">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <owl:disjointWith rdf:resource="https://w3id.org/mdivo#UserNotice"/>
        <rdfs:comment xml:lang="en">FSCA performed at the location where the device is installed</rdfs:comment>
        <rdfs:label xml:lang="en">In Situ Correction</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#InVitroDiagnosticDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#InVitroDiagnosticDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">Reagent, calibrator, instrument or system intended for in-vitro examination of specimens from the human body</rdfs:comment>
        <rdfs:label xml:lang="en">In-Vitro Diagnostic Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#Incident -->


    <owl:Class rdf:about="https://w3id.org/mdivo#Incident">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#affectsDevice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#realizesRisk"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/mdivo#Risk"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">Any malfunction or deterioration in the characteristics or performance of a device that has led, might have led or might lead to harm to a patient or user</rdfs:comment>
        <rdfs:label xml:lang="en">Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#InfectionRisk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#InfectionRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">Risk of infection associated with device use</rdfs:comment>
        <rdfs:label xml:lang="en">Infection Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#InjuryRisk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#InjuryRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">Risk of physical harm to the patient or user resulting from device use</rdfs:comment>
        <rdfs:label xml:lang="en">Injury Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#MDR -->


    <owl:Class rdf:about="https://w3id.org/mdivo#MDR">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#RegulatoryFramework"/>
        <rdfs:comment xml:lang="en">Regulation (EU) 2017/745 on medical devices</rdfs:comment>
        <rdfs:label xml:lang="en">MDR Framework</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#MalfunctionRisk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#MalfunctionRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">Risk of failure of the device to perform as intended</rdfs:comment>
        <rdfs:label xml:lang="en">Malfunction Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#Manufacturer -->


    <owl:Class rdf:about="https://w3id.org/mdivo#Manufacturer">
        <rdfs:comment xml:lang="en">Legal or natural person who manufactures or refurbishes a medical device and markets it under its own name.</rdfs:comment>
        <rdfs:label xml:lang="en">Manufacturer</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#MedicalDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#MedicalDevice">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#fallsUnder"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/mdivo#RegulatoryFramework"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#hasRiskClass"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/mdivo#RiskClass"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#isManufacturedBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://w3id.org/mdivo#Manufacturer"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://w3id.org/mdivo#hasUDI"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment xml:lang="en">A device, instrument, apparatus, software, implant or in-vitro reagent intended by the manufacturer for medical use.</rdfs:comment>
        <rdfs:label xml:lang="en">Medical Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#NearMissIncident -->


    <owl:Class rdf:about="https://w3id.org/mdivo#NearMissIncident">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Incident"/>
        <owl:disjointWith rdf:resource="https://w3id.org/mdivo#SeriousIncident"/>
        <rdfs:comment xml:lang="en">Incident detected before causing harm to the patient or user; tracked for trend analysis under PMS obligations</rdfs:comment>
        <rdfs:label xml:lang="en">Near Miss Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#Recall -->


    <owl:Class rdf:about="https://w3id.org/mdivo#Recall">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:comment xml:lang="en">FSCA consisting in the removal of affected devices from the market and from end users</rdfs:comment>
        <rdfs:label xml:lang="en">Recall</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#RegulatoryFramework -->


    <owl:Class rdf:about="https://w3id.org/mdivo#RegulatoryFramework">
        <rdfs:comment xml:lang="en">The European regulation that governs the marketing of a given device.</rdfs:comment>
        <rdfs:label xml:lang="en">Regulatory Framework</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#Risk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#Risk">
        <rdfs:comment xml:lang="en">An identified hazard that may be caused by or associated with a medical device</rdfs:comment>
        <rdfs:label xml:lang="en">Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#RiskClass -->


    <owl:Class rdf:about="https://w3id.org/mdivo#RiskClass">
        <rdfs:label xml:lang="en">Risk Class</rdfs:label>
        <rdfs:label xml:lang="en">Risk classification scheme</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#SafetyAlert -->


    <owl:Class rdf:about="https://w3id.org/mdivo#SafetyAlert">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:comment xml:lang="en">Field Safety Notice issued to inform users of a hazard without removing the device from the market.</rdfs:comment>
        <rdfs:label xml:lang="en">Safety Alert</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#SelfTestDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#SelfTestDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#InVitroDiagnosticDevice"/>
        <rdfs:comment xml:lang="en">An IVD device intended by the manufacturer to be used by lay persons</rdfs:comment>
        <rdfs:label xml:lang="en">Self Test Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#SeriousIncident -->


    <owl:Class rdf:about="https://w3id.org/mdivo#SeriousIncident">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Incident"/>
        <rdfs:comment xml:lang="en">Incident that directly or indirectly led, might have led or might lead to death or serious deterioration in health</rdfs:comment>
        <rdfs:label xml:lang="en">Serious Incident</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#SingleUseDevice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#SingleUseDevice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#MedicalDevice"/>
        <rdfs:comment xml:lang="en">A device intended to be used on a single individual during a single procedure</rdfs:comment>
        <rdfs:label xml:lang="en">Single Use Device</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#SoftwareRisk -->


    <owl:Class rdf:about="https://w3id.org/mdivo#SoftwareRisk">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#Risk"/>
        <rdfs:comment xml:lang="en">Risk arising from software defects, including embedded firmware</rdfs:comment>
        <rdfs:label xml:lang="en">Software Risk</rdfs:label>
    </owl:Class>
    


    <!-- https://w3id.org/mdivo#UserNotice -->


    <owl:Class rdf:about="https://w3id.org/mdivo#UserNotice">
        <rdfs:subClassOf rdf:resource="https://w3id.org/mdivo#FSCA"/>
        <rdfs:comment xml:lang="en">Communication to end users updating instructions for use, contraindications or training requirements.</rdfs:comment>
        <rdfs:label xml:lang="en">User Notice</rdfs:label>
    </owl:Class>
    


